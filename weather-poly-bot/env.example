# Copy this file to `.env` and fill in your real values.
# NEVER commit `.env` to git.

# Your Telegram bot token from @BotFather
BOT_TOKEN=8687484106:AAEh_89IpfQQ91rIEUJsGRTDZFjZDvs_a1I

# Where the SQLite tracking DB lives
DB_PATH=weather_bot.db

# Path to the OurAirports CSV (downloaded automatically on first run if missing)
AIRPORTS_CSV=data/airports.csv

# How often the tracking loop checks for forecast changes (in minutes)
TRACKING_INTERVAL_MINUTES=30

# Alert thresholds
ALERT_THRESHOLD_C=1.0
ALERT_THRESHOLD_F=2.0

# Logging verbosity (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# OpenWeather API key (optional). When set, OpenWeather's daily-max forecast
# is added to the ensemble with a ~5% weight as a cross-source check.
# Get a free key at https://openweathermap.org/api  (One Call API 3.0).
# Leave blank to skip OpenWeather entirely.
OPENWEATHER_API_KEY=
